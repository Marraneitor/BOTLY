# ============================================
# 🍔 Sr y Sra Burger — Bot WhatsApp con IA
# ============================================
# Copia este archivo como .env y rellena los valores

# --- Google Gemini ---
# Obtén tu API key en https://aistudio.google.com/apikey
GEMINI_API_KEY=tu-api-key-aqui
GEMINI_MODEL=gemini-2.0-flash

# --- Flask ---
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
FLASK_SECRET_KEY=cambia-esta-clave-secreta

# --- WhatsApp Bridge ---
BRIDGE_URL=http://127.0.0.1:3001

# --- Bot ---
# true = responde automáticamente, false = solo sugiere respuestas
AUTO_REPLY=true
# Segundos a esperar desde el ÚLTIMO mensaje del cliente antes de responder.
# Ej: 3 = agrupa mensajes seguidos y contesta 1 sola vez.
# Pon 0 para desactivar (responder inmediatamente).
MESSAGE_DEBOUNCE_SECONDS=3
# Número máximo de mensajes a recordar por conversación
MAX_HISTORY_PER_CHAT=20
# Contactos a ignorar (separados por coma, dejar vacío para ninguno)
IGNORED_CONTACTS=

# --- Notificaciones de pedidos (a tu WhatsApp) ---
# true = te manda un mensaje cuando se confirma un pedido completo
NOTIFY_OWNER_ON_NEW_ORDER=true
# true = te manda un mensaje cuando escribe un cliente nuevo (primer mensaje de ese chat durante esta ejecución)
NOTIFY_OWNER_ON_NEW_CUSTOMER=true
# Recomendado: tu chatId de WhatsApp (con @c.us)
# Ej: 5219221234567@c.us
OWNER_WHATSAPP_CHAT_ID=
# Alternativa: tu teléfono (se convertirá a @c.us automáticamente)
OWNER_PHONE=
